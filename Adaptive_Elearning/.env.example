# ------------ Global -------------
APP_ENV=prod
TZ=UTC

# ------------ Database -------------
DB_HOST=mssql
DB_PORT=1433
DB_NAME=CourseHubDB
DB_USER=sa
DB_PASSWORD=ChangeMe123!@#
MSSQL_SA_PASSWORD=ChangeMe123!@#
MSSQL_COLLATION=SQL_Latin1_General_CP1_CI_AS

# ------------ Java Web App -------------
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://example.com/oauth2callback

# ------------ CAT Service -------------
CAT_DB_SERVER=mssql
CAT_DB_PORT=1433
CAT_DB_NAME=CourseHubDB
CAT_DB_USER=cat_user
CAT_DB_PASSWORD=ChangeMe123!@#
CAT_DB_DRIVER=ODBC Driver 18 for SQL Server
CAT_DB_ENCRYPT=yes
CAT_DB_TRUST_CERT=yes
CAT_DB_TIMEOUT=30

# ------------ AI Advisor Service -------------
AI_DB_SERVER=mssql
AI_DB_PORT=1433
AI_DB_NAME=CourseHubDB
AI_DB_USER=ai_user
AI_DB_PASSWORD=ChangeMe123!@#
AI_DB_DRIVER=ODBC Driver 18 for SQL Server
AI_DB_ENCRYPT=yes
AI_DB_TRUST_CERT=yes
AI_DB_TIMEOUT=30
OLLAMA_URL=https://api.your-ollama-endpoint.com/chat
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_API_KEY=change-me
OLLAMA_TIMEOUT=30

# ------------ Networking -------------
PUBLIC_BASE_URL=https://adaptive.example.com
NGINX_SERVER_NAME=adaptive.example.com
NGINX_RATE_LIMIT=10r/s
TLS_CERT_PATH=/etc/letsencrypt/live/adaptive.example.com/fullchain.pem
TLS_KEY_PATH=/etc/letsencrypt/live/adaptive.example.com/privkey.pem